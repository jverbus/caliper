# Shared profile (multi-tenant service with auth enabled)
CALIPER_PROFILE=shared
CALIPER_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/caliper
CALIPER_DATA_DIR=./data
CALIPER_REPORTS_DIR=./reports
CALIPER_EXPORTS_DIR=./exports
CALIPER_API_HOST=0.0.0.0
CALIPER_API_PORT=8000
CALIPER_AUTH_ENABLED=true
CALIPER_DEFAULT_WORKSPACE_ID=ws_default
# Example secret value; override in deployment secret store
CALIPER_SHARED_API_TOKEN=replace-me
